<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>ADHD Focus OS</title>
  <style>
    :root {
      --bg: #090b10;
      --panel: #111722;
      --panel2: #151d2b;
      --text: #f4f7fb;
      --muted: #9aa7b7;
      --line: rgba(255,255,255,.08);
      --accent: #7c5cff;
      --accent2: #36d399;
      --danger: #ff5c7a;
      --warning: #ffd166;
      --shadow: 0 18px 45px rgba(0,0,0,.35);
      --radius: 22px;
    }

    * {
      box-sizing: border-box;
      -webkit-tap-highlight-color: transparent;
    }

    body {
      margin: 0;
      min-height: 100vh;
      font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background:
        radial-gradient(circle at top left, rgba(124,92,255,.22), transparent 34%),
        radial-gradient(circle at bottom right, rgba(54,211,153,.13), transparent 30%),
        var(--bg);
      color: var(--text);
    }

    button, input, textarea {
      font: inherit;
    }

    button {
      border: 0;
      cursor: pointer;
      color: var(--text);
      touch-action: manipulation;
    }

    .app {
      width: min(1120px, 100%);
      margin: 0 auto;
      padding: 18px;
    }

    header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      margin-bottom: 18px;
    }

    .brand {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .logo {
      width: 44px;
      height: 44px;
      border-radius: 16px;
      background: linear-gradient(135deg, var(--accent), #28d9ff);
      display: grid;
      place-items: center;
      font-weight: 900;
      box-shadow: 0 12px 30px rgba(124,92,255,.35);
    }

    h1 {
      font-size: 1.15rem;
      margin: 0;
      letter-spacing: .02em;
    }

    .subtitle {
      color: var(--muted);
      font-size: .82rem;
      margin-top: 2px;
    }

    .stats {
      background: rgba(255,255,255,.06);
      border: 1px solid var(--line);
      border-radius: 999px;
      padding: 10px 14px;
      font-weight: 800;
      white-space: nowrap;
    }

    .grid {
      display: grid;
      grid-template-columns: 1.1fr .9fr;
      gap: 16px;
    }

    .card {
      background: linear-gradient(180deg, rgba(255,255,255,.07), rgba(255,255,255,.035));
      border: 1px solid var(--line);
      border-radius: var(--radius);
      padding: 18px;
      box-shadow: var(--shadow);
      backdrop-filter: blur(14px);
    }

    .hero {
      min-height: 270px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      gap: 18px;
    }

    .label {
      color: var(--muted);
      font-size: .82rem;
      font-weight: 700;
      letter-spacing: .08em;
      text-transform: uppercase;
    }

    .now-task {
      font-size: clamp(2rem, 7vw, 4.8rem);
      line-height: 1.03;
      letter-spacing: -.06em;
      font-weight: 950;
      margin: 8px 0 0;
      word-break: break-word;
    }

    .empty-now {
      color: var(--muted);
      font-size: clamp(1.8rem, 6vw, 3.8rem);
      line-height: 1.05;
      font-weight: 900;
      letter-spacing: -.05em;
    }

    .focus-actions {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
    }

    .btn {
      min-height: 52px;
      border-radius: 16px;
      padding: 13px 15px;
      font-weight: 850;
      background: var(--panel2);
      border: 1px solid var(--line);
      transition: transform .12s ease, opacity .12s ease, background .12s ease;
    }

    .btn:active {
      transform: scale(.97);
    }

    .btn.primary {
      background: linear-gradient(135deg, var(--accent), #4bb8ff);
      box-shadow: 0 14px 28px rgba(124,92,255,.25);
    }

    .btn.done {
      background: linear-gradient(135deg, var(--accent2), #19a974);
      color: #03120c;
    }

    .btn.danger {
      background: rgba(255,92,122,.14);
      color: #ffd6de;
      border-color: rgba(255,92,122,.28);
    }

    .btn.ghost {
      background: rgba(255,255,255,.045);
    }

    .section-title {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      margin-bottom: 12px;
    }

    h2 {
      font-size: .98rem;
      margin: 0;
    }

    .count {
      color: var(--muted);
      font-size: .82rem;
      font-weight: 700;
    }

    .task-input {
      display: flex;
      gap: 8px;
      margin-bottom: 12px;
    }

    input, textarea {
      width: 100%;
      border: 1px solid var(--line);
      background: rgba(0,0,0,.18);
      color: var(--text);
      border-radius: 16px;
      outline: none;
    }

    input {
      min-height: 52px;
      padding: 0 14px;
    }

    textarea {
      min-height: 112px;
      resize: vertical;
      padding: 14px;
      line-height: 1.5;
    }

    input:focus, textarea:focus {
      border-color: rgba(124,92,255,.75);
      box-shadow: 0 0 0 4px rgba(124,92,255,.12);
    }

    .add-btn {
      width: 86px;
      flex: 0 0 86px;
    }

    .tasks {
      display: grid;
      gap: 9px;
    }

    .task {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 10px;
      align-items: center;
      padding: 12px;
      background: rgba(255,255,255,.045);
      border: 1px solid var(--line);
      border-radius: 18px;
    }

    .task:first-child {
      background: rgba(124,92,255,.15);
      border-color: rgba(124,92,255,.35);
    }

    .task-title {
      font-weight: 800;
      line-height: 1.35;
      word-break: break-word;
    }

    .task-tools {
      display: flex;
      gap: 6px;
    }

    .mini {
      width: 42px;
      height: 42px;
      border-radius: 14px;
      background: rgba(255,255,255,.07);
      border: 1px solid var(--line);
      font-weight: 900;
    }

    .mini:disabled {
      opacity: .35;
      cursor: not-allowed;
    }

    .timer {
      text-align: center;
    }

    .time {
      font-size: clamp(3.1rem, 12vw, 5.4rem);
      line-height: 1;
      font-weight: 950;
      letter-spacing: -.07em;
      margin: 16px 0;
      font-variant-numeric: tabular-nums;
    }

    .timer-presets {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 8px;
      margin-bottom: 10px;
    }

    .timer-actions {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
    }

    .inbox-list, .log-list {
      display: grid;
      gap: 8px;
      max-height: 230px;
      overflow: auto;
      padding-right: 2px;
    }

    .note, .log {
      background: rgba(255,255,255,.045);
      border: 1px solid var(--line);
      border-radius: 16px;
      padding: 11px 12px;
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 10px;
      align-items: start;
    }

    .note p, .log p {
      margin: 0;
      color: #dbe5f2;
      line-height: 1.45;
      word-break: break-word;
    }

    .meta {
      display: block;
      color: var(--muted);
      font-size: .72rem;
      margin-top: 4px;
      font-weight: 650;
    }

    .hint {
      color: var(--muted);
      font-size: .83rem;
      line-height: 1.45;
      margin: 10px 0 0;
    }

    .stack {
      display: grid;
      gap: 16px;
    }

    .toast {
      position: fixed;
      left: 50%;
      bottom: 22px;
      transform: translateX(-50%) translateY(20px);
      background: rgba(12,18,28,.92);
      border: 1px solid rgba(54,211,153,.35);
      color: #dffff0;
      padding: 14px 18px;
      border-radius: 999px;
      box-shadow: var(--shadow);
      opacity: 0;
      pointer-events: none;
      transition: .25s ease;
      font-weight: 850;
      z-index: 10;
    }

    .toast.show {
      opacity: 1;
      transform: translateX(-50%) translateY(0);
    }

    .celebrate {
      position: fixed;
      inset: 0;
      pointer-events: none;
      overflow: hidden;
      z-index: 9;
    }

    .spark {
      position: absolute;
      width: 8px;
      height: 14px;
      border-radius: 999px;
      animation: pop 760ms ease-out forwards;
      background: var(--accent2);
    }

    @keyframes pop {
      0% {
        transform: translateY(0) rotate(0deg) scale(1);
        opacity: 1;
      }
      100% {
        transform: translateY(130px) rotate(210deg) scale(.5);
        opacity: 0;
      }
    }

    .shake {
      animation: shake .28s ease;
    }

    @keyframes shake {
      0%, 100% { transform: translateX(0); }
      25% { transform: translateX(-5px); }
      75% { transform: translateX(5px); }
    }

    @media (max-width: 820px) {
      .app {
        padding: 14px;
      }

      .grid {
        grid-template-columns: 1fr;
      }

      header {
        align-items: flex-start;
      }

      .stats {
        font-size: .86rem;
      }

      .focus-actions,
      .timer-actions {
        grid-template-columns: 1fr;
      }

      .task-input {
        display: grid;
        grid-template-columns: 1fr;
      }

      .add-btn {
        width: 100%;
        flex: initial;
      }
    }
  </style>
</head>
<body>
  <div class="app">
    <header>
      <div class="brand">
        <div class="logo">OS</div>
        <div>
          <h1>ADHD Focus OS</h1>
          <div class="subtitle">今日は3つまで。今は1つだけ。</div>
        </div>
      </div>
      <div class="stats">今日の達成：<span id="todayDone">0</span></div>
    </header>

    <main class="grid">
      <section class="stack">
        <div class="card hero">
          <div>
            <div class="label">NOW</div>
            <div id="nowTask" class="empty-now">まず1つ登録しよう</div>
          </div>
          <div class="focus-actions">
            <button id="completeNowBtn" class="btn done">完了する</button>
            <button id="start25Btn" class="btn primary">25分集中</button>
          </div>
        </div>

        <div class="card">
          <div class="section-title">
            <h2>今日やること</h2>
            <div class="count"><span id="taskCount">0</span>/3</div>
          </div>

          <div class="task-input">
            <input id="taskInput" maxlength="60" placeholder="例：資料を1ページだけ読む" />
            <button id="addTaskBtn" class="btn primary add-btn">追加</button>
          </div>

          <div id="tasks" class="tasks"></div>
          <p class="hint">迷ったら一番上だけやる。追加しすぎ防止のため、タスクは最大3つまで。</p>
        </div>

        <div class="card">
          <div class="section-title">
            <h2>思いつき Inbox</h2>
            <button id="clearInboxBtn" class="btn ghost" style="min-height:40px;padding:8px 12px;">整理済み</button>
          </div>
          <textarea id="inboxInput" placeholder="今やること以外はここへ逃がす。例：あとで調べる、買うもの、思いつき"></textarea>
          <button id="saveInboxBtn" class="btn primary" style="width:100%;margin:10px 0 12px;">Inboxに保存</button>
          <div id="inboxList" class="inbox-list"></div>
        </div>
      </section>

      <aside class="stack">
        <div class="card timer">
          <div class="section-title">
            <h2>集中タイマー</h2>
            <div class="count" id="timerLabel">待機中</div>
          </div>

          <div class="timer-presets">
            <button class="btn ghost preset" data-min="5">5分</button>
            <button class="btn ghost preset" data-min="15">15分</button>
            <button class="btn ghost preset" data-min="25">25分</button>
          </div>

          <div id="time" class="time">25:00</div>

          <div class="timer-actions">
            <button id="toggleTimerBtn" class="btn primary">開始</button>
            <button id="resetTimerBtn" class="btn ghost">リセット</button>
          </div>
        </div>

        <div class="card">
          <div class="section-title">
            <h2>完了ログ</h2>
            <button id="clearLogsBtn" class="btn ghost" style="min-height:40px;padding:8px 12px;">ログ削除</button>
          </div>
          <div id="logList" class="log-list"></div>
        </div>

        <div class="card">
          <div class="section-title">
            <h2>リセット</h2>
          </div>
          <p class="hint" style="margin-top:0;">今日のタスクとタイマーだけリセット。Inboxと完了ログは残る。</p>
          <button id="resetDayBtn" class="btn danger" style="width:100%;margin-top:10px;">今日をリセット</button>
        </div>
      </aside>
    </main>
  </div>

  <div id="toast" class="toast">できた。えらい。</div>
  <div id="celebrate" class="celebrate"></div>

  <script>
    const STORAGE_KEY = "adhd_focus_os_v1";

    const $ = (id) => document.getElementById(id);

    const todayKey = () => {
      const d = new Date();
      const y = d.getFullYear();
      const m = String(d.getMonth() + 1).padStart(2, "0");
      const day = String(d.getDate()).padStart(2, "0");
      return `${y}-${m}-${day}`;
    };

    const defaultState = {
      tasks: [],
      inbox: [],
      logs: [],
      timer: {
        selectedMinutes: 25,
        remaining: 25 * 60,
        running: false,
        startedAt: null
      }
    };

    let state = loadState();
    let timerInterval = null;

    function loadState() {
      try {
        const saved = JSON.parse(localStorage.getItem(STORAGE_KEY));
        return saved ? { ...defaultState, ...saved } : structuredClone(defaultState);
      } catch {
        return structuredClone(defaultState);
      }
    }

    function saveState() {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
    }

    function uid() {
      return Date.now().toString(36) + Math.random().toString(36).slice(2);
    }

    function escapeHtml(str) {
      return String(str)
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");
    }

    function render() {
      renderNow();
      renderTasks();
      renderInbox();
      renderLogs();
      renderTimer();
      renderStats();
      saveState();
    }

    function renderNow() {
      const now = state.tasks[0];
      const el = $("nowTask");

      if (!now) {
        el.className = "empty-now";
        el.textContent = "まず1つ登録しよう";
        $("completeNowBtn").disabled = true;
      } else {
        el.className = "now-task";
        el.textContent = now.title;
        $("completeNowBtn").disabled = false;
      }
    }

    function renderTasks() {
      $("taskCount").textContent = state.tasks.length;
      $("taskInput").disabled = state.tasks.length >= 3;
      $("addTaskBtn").disabled = state.tasks.length >= 3;

      if (state.tasks.length >= 3) {
        $("taskInput").placeholder = "今日はここまで。3つ以上はInboxへ。";
      } else {
        $("taskInput").placeholder = "例：資料を1ページだけ読む";
      }

      $("tasks").innerHTML = state.tasks.map((task, index) => `
        <div class="task">
          <div>
            <div class="task-title">${escapeHtml(task.title)}</div>
            ${index === 0 ? '<span class="meta">今やる1つ</span>' : ''}
          </div>
          <div class="task-tools">
            <button class="mini" onclick="moveTask('${task.id}', -1)" ${index === 0 ? "disabled" : ""}>↑</button>
            <button class="mini" onclick="moveTask('${task.id}', 1)" ${index === state.tasks.length - 1 ? "disabled" : ""}>↓</button>
            <button class="mini" onclick="completeTask('${task.id}')">✓</button>
            <button class="mini" onclick="deleteTask('${task.id}')">×</button>
          </div>
        </div>
      `).join("");
    }

    function renderInbox() {
      if (state.inbox.length === 0) {
        $("inboxList").innerHTML = `<p class="hint">Inboxは空。思考が散らかったらここに逃がそう。</p>`;
        return;
      }

      $("inboxList").innerHTML = state.inbox.map(item => `
        <div class="note">
          <div>
            <p>${escapeHtml(item.text)}</p>
            <span class="meta">${escapeHtml(item.date)}</span>
          </div>
          <button class="mini" onclick="deleteInbox('${item.id}')">×</button>
        </div>
      `).join("");
    }

    function renderLogs() {
      const logs = [...state.logs].reverse();

      if (logs.length === 0) {
        $("logList").innerHTML = `<p class="hint">まだログなし。1つ終わらせたらここに残る。</p>`;
        return;
      }

      $("logList").innerHTML = logs.map(log => `
        <div class="log">
          <div>
            <p>${escapeHtml(log.title)}</p>
            <span class="meta">${escapeHtml(log.date)}</span>
          </div>
        </div>
      `).join("");
    }

    function renderStats() {
      const count = state.logs.filter(log => log.day === todayKey()).length;
      $("todayDone").textContent = count;
    }

    function renderTimer() {
      const min = Math.floor(state.timer.remaining / 60);
      const sec = state.timer.remaining % 60;
      $("time").textContent = `${String(min).padStart(2, "0")}:${String(sec).padStart(2, "0")}`;
      $("toggleTimerBtn").textContent = state.timer.running ? "一時停止" : "開始";
      $("timerLabel").textContent = state.timer.running ? "集中中" : `${state.timer.selectedMinutes}分`;
    }

    function addTask() {
      const input = $("taskInput");
      const title = input.value.trim();

      if (!title) return;

      if (state.tasks.length >= 3) {
        warnLimit();
        return;
      }

      state.tasks.push({ id: uid(), title, createdAt: new Date().toISOString() });
      input.value = "";
      render();
    }

    function deleteTask(id) {
      state.tasks = state.tasks.filter(task => task.id !== id);
      render();
    }

    function completeTask(id) {
      const task = state.tasks.find(t => t.id === id);
      if (!task) return;

      state.tasks = state.tasks.filter(t => t.id !== id);
      state.logs.push({
        id: uid(),
        title: task.title,
        day: todayKey(),
        date: new Date().toLocaleString("ja-JP", {
          year: "numeric",
          month: "2-digit",
          day: "2-digit",
          hour: "2-digit",
          minute: "2-digit"
        })
      });

      celebrate();
      toast("完了。ちゃんと前に進んだ。");
      render();
    }

    function completeNow() {
      if (state.tasks[0]) completeTask(state.tasks[0].id);
    }

    function moveTask(id, direction) {
      const index = state.tasks.findIndex(task => task.id === id);
      const nextIndex = index + direction;

      if (index < 0 || nextIndex < 0 || nextIndex >= state.tasks.length) return;

      const copy = [...state.tasks];
      [copy[index], copy[nextIndex]] = [copy[nextIndex], copy[index]];
      state.tasks = copy;
      render();
    }

    function saveInbox() {
      const input = $("inboxInput");
      const text = input.value.trim();

      if (!text) return;

      state.inbox.unshift({
        id: uid(),
        text,
        date: new Date().toLocaleString("ja-JP", {
          month: "2-digit",
          day: "2-digit",
          hour: "2-digit",
          minute: "2-digit"
        })
      });

      input.value = "";
      toast("Inboxに逃がした。今は目の前だけ。");
      render();
    }

    function deleteInbox(id) {
      state.inbox = state.inbox.filter(item => item.id !== id);
      render();
    }

    function clearInbox() {
      state.inbox = [];
      toast("Inboxを空にした。");
      render();
    }

    function clearLogs() {
      if (!confirm("完了ログをすべて削除しますか？")) return;
      state.logs = [];
      render();
    }

    function setTimer(minutes) {
      pauseTimer();
      state.timer.selectedMinutes = minutes;
      state.timer.remaining = minutes * 60;
      render();
    }

    function startTimer() {
      if (state.timer.running) return;

      state.timer.running = true;
      state.timer.startedAt = Date.now();

      timerInterval = setInterval(() => {
        if (state.timer.remaining > 0) {
          state.timer.remaining -= 1;
          renderTimer();
          saveState();
        } else {
          pauseTimer();
          toast("タイマー終了。一区切りつけよう。");
          celebrate();
          render();
        }
      }, 1000);

      render();
    }

    function pauseTimer() {
      state.timer.running = false;
      state.timer.startedAt = null;

      if (timerInterval) {
        clearInterval(timerInterval);
        timerInterval = null;
      }

      render();
    }

    function toggleTimer() {
      state.timer.running ? pauseTimer() : startTimer();
    }

    function resetTimer() {
      pauseTimer();
      state.timer.remaining = state.timer.selectedMinutes * 60;
      render();
    }

    function resetToday() {
      if (!confirm("今日のタスクとタイマーをリセットしますか？")) return;

      pauseTimer();
      state.tasks = [];
      state.timer = {
        selectedMinutes: 25,
        remaining: 25 * 60,
        running: false,
        startedAt: null
      };

      toast("今日をリセットした。ここから再開。");
      render();
    }

    function warnLimit() {
      const card = $("taskInput");
      card.classList.remove("shake");
      void card.offsetWidth;
      card.classList.add("shake");
      toast("タスクは3つまで。残りはInboxへ。");
    }

    function toast(message) {
      const el = $("toast");
      el.textContent = message;
      el.classList.add("show");

      clearTimeout(window.__toastTimer);
      window.__toastTimer = setTimeout(() => {
        el.classList.remove("show");
      }, 1800);
    }

    function celebrate() {
      const area = $("celebrate");
      const colors = ["#36d399", "#7c5cff", "#28d9ff", "#ffd166", "#ff5c7a"];

      for (let i = 0; i < 24; i++) {
        const spark = document.createElement("div");
        spark.className = "spark";
        spark.style.left = Math.random() * 100 + "%";
        spark.style.top = "8%";
        spark.style.background = colors[Math.floor(Math.random() * colors.length)];
        spark.style.animationDelay = Math.random() * 180 + "ms";
        spark.style.transform = `rotate(${Math.random() * 180}deg)`;
        area.appendChild(spark);

        setTimeout(() => spark.remove(), 1000);
      }
    }

    $("addTaskBtn").addEventListener("click", addTask);
    $("taskInput").addEventListener("keydown", (e) => {
      if (e.key === "Enter") addTask();
    });

    $("completeNowBtn").addEventListener("click", completeNow);
    $("start25Btn").addEventListener("click", () => {
      setTimer(25);
      startTimer();
    });

    $("saveInboxBtn").addEventListener("click", saveInbox);
    $("clearInboxBtn").addEventListener("click", clearInbox);
    $("clearLogsBtn").addEventListener("click", clearLogs);
    $("resetDayBtn").addEventListener("click", resetToday);

    document.querySelectorAll(".preset").forEach(btn => {
      btn.addEventListener("click", () => setTimer(Number(btn.dataset.min)));
    });

    $("toggleTimerBtn").addEventListener("click", toggleTimer);
    $("resetTimerBtn").addEventListener("click", resetTimer);

    window.moveTask = moveTask;
    window.deleteTask = deleteTask;
    window.completeTask = completeTask;
    window.deleteInbox = deleteInbox;

    render();
  </script>
</body>
</html>